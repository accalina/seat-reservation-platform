{
  "name": "seat-reservation-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun run src/db/migrate.ts && bun test",
    "test:watch": "bun run src/db/migrate.ts && bun test --watch",
    "test:coverage": "bun run src/db/migrate.ts && bun test --coverage",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:setup": "bun run src/db/migrate.ts && bun run src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:backup": "bun run src/db/backup.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.2",
    "@sinclair/typebox": "^0.34.49",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "test": {
    "coverage": {
      "include": ["src/**/*.ts"],
      "exclude": ["src/db/migrate.ts", "src/db/seed.ts"],
      "thresholds": {
        "lines": 80,
        "functions": 80
      }
    }
  }
}